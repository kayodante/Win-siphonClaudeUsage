{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Siphon",
  "version": "1.7.0",
  "identifier": "com.kayodantes.siphon",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "renderer/index.html",
        "title": "Siphon",
        "width": 320,
        "height": 700,
        "minWidth": 310,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "center": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "../src/assets/installer/icon.ico",
        "headerImage": "../src/assets/installer/installer-header.bmp",
        "sidebarImage": "../src/assets/installer/installer-sidebar.bmp"
      }
    }
  },
  "plugins": {}
}
