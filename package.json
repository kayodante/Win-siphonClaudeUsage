{
  "name": "siphon-windows",
  "version": "1.6.0",
  "description": "Windows tray app for Claude Code usage and reset notifications.",
  "main": "src/main/main.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kayodante/Win-siphonClaudeUsage.git"
  },
  "bugs": {
    "url": "https://github.com/kayodante/Win-siphonClaudeUsage/issues"
  },
  "homepage": "https://github.com/kayodante/Win-siphonClaudeUsage#readme",
  "scripts": {
    "start": "cd src-tauri && cargo tauri dev",
    "build:win": "cd src-tauri && cargo tauri build",
    "start:electron": "electron .",
    "build:win:electron": "electron-builder --win",
    "test": "node --test test/*.test.js",
    "lint": "node scripts/check-syntax.js && eslint .",
    "fallow": "fallow"
  },
  "keywords": [
    "claude",
    "usage",
    "tray",
    "windows"
  ],
  "productName": "Siphon",
  "author": "Kayo Dante",
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.0.0",
    "fallow": "^2.102.0",
    "globals": "^16.0.0"
  },
  "allowScripts": {
    "electron@41.3.0": true,
    "electron-winstaller@5.4.0": true
  }
}
