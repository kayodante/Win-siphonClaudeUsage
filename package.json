{
  "name": "siphon-windows",
  "version": "1.7.3",
  "description": "Windows tray app for Claude Code usage and reset notifications.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kayodante/Win-siphonClaudeUsage.git"
  },
  "bugs": {
    "url": "https://github.com/kayodante/Win-siphonClaudeUsage/issues"
  },
  "homepage": "https://github.com/kayodante/Win-siphonClaudeUsage#readme",
  "scripts": {
    "start": "cd src-tauri && cargo tauri dev",
    "build:win": "cd src-tauri && cargo tauri build",
    "pack:release": "pwsh -NoProfile -File scripts/pack-release.ps1",
    "test": "node --test test/*.test.js",
    "test:rust": "cargo test -p siphon-core --manifest-path src-tauri/Cargo.toml",
    "lint": "node scripts/check-syntax.js && eslint .",
    "fallow": "fallow"
  },
  "keywords": [
    "claude",
    "usage",
    "tray",
    "windows"
  ],
  "productName": "Siphon",
  "author": "Kayo Dante",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.0.0",
    "fallow": "^2.102.0",
    "globals": "^16.0.0"
  }
}
